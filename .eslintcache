[{"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/index.js":"1","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/App.js":"2","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/UserList.js":"3","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/Dashboard.js":"4","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/Header.js":"5","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/List.js":"6","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/PrivateRoute.js":"7","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/Add.js":"8","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/Login.js":"9","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/Detail.js":"10","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/AdminRoute.js":"11","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/ManagerRoute.js":"12","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/contexts/AuthContext.js":"13","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/firebase.js":"14","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/utils/index.js":"15"},{"size":254,"mtime":1609684282000,"results":"16","hashOfConfig":"17"},{"size":1729,"mtime":1656243157000,"results":"18","hashOfConfig":"17"},{"size":3918,"mtime":1697961470935,"results":"19","hashOfConfig":"17"},{"size":8413,"mtime":1697973263890,"results":"20","hashOfConfig":"17"},{"size":1550,"mtime":1656242873000,"results":"21","hashOfConfig":"17"},{"size":5677,"mtime":1697962283013,"results":"22","hashOfConfig":"17"},{"size":441,"mtime":1617028477000,"results":"23","hashOfConfig":"17"},{"size":6866,"mtime":1656245944000,"results":"24","hashOfConfig":"17"},{"size":1868,"mtime":1609685126000,"results":"25","hashOfConfig":"17"},{"size":7503,"mtime":1697963298254,"results":"26","hashOfConfig":"17"},{"size":543,"mtime":1617030785000,"results":"27","hashOfConfig":"17"},{"size":585,"mtime":1656243195000,"results":"28","hashOfConfig":"17"},{"size":1857,"mtime":1656243934000,"results":"29","hashOfConfig":"17"},{"size":642,"mtime":1609688312000,"results":"30","hashOfConfig":"17"},{"size":676,"mtime":1697960193761,"results":"31","hashOfConfig":"17"},{"filePath":"32","messages":"33","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"5g4joo",{"filePath":"34","messages":"35","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"36","messages":"37","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"38","messages":"39","errorCount":0,"fatalErrorCount":0,"warningCount":6,"fixableErrorCount":0,"fixableWarningCount":0,"source":"40"},{"filePath":"41","messages":"42","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"43","messages":"44","errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"45","messages":"46","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"47"},{"filePath":"48","messages":"49","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"50","messages":"51","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"52","messages":"53","errorCount":0,"fatalErrorCount":0,"warningCount":6,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"54","messages":"55","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"56","messages":"57","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"58","messages":"59","errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"60"},{"filePath":"61","messages":"62","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"63","messages":"64","errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/index.js",[],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/App.js",[],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/UserList.js",[],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/Dashboard.js",["65","66","67","68","69","70"],"import React, { useState, useEffect } from \"react\";\nimport { Card, Button, Alert } from \"react-bootstrap\";\nimport { Link } from \"react-router-dom\";\nimport { useAuth } from \"../contexts/AuthContext\";\nimport app from \"../firebase\";\n// import _ from \"underscore\";\nlet _ = require(\"underscore\");\n\nexport default function Dashboard(props) {\n  const [pendingOrders, setPendingOrders] = useState([]);\n  const [pendingOrdersCount, setPendingOrdersCount] = useState(0);\n  const [statusOrders, setStatusOrders] = useState([]);\n  const [statusOrdersSum, setStatusOrdersSum] = useState([]);\n  const [initOrderList, setInitOrderList] = useState([]);\n  const [initOrderHistoryList, setInitOrderHistoryList] = useState([]);\n  const [loading, setLoading] = useState(false);\n  const [date, setDate] = useState(getToday());\n  const [error, setError] = useState(\"\");\n  const [showMore, setShowMore] = useState(\"\");\n  // const { currentUser, isAdmin, logout } = useAuth();\n  const [orderDetailsForDate, setOrderDetailsForDate] = useState({});\n\n  function getDateFromString(_date) {\n    let date = new Date(_date);\n    return `${date.getDate()}-${date.getMonth() + 1}-${date.getFullYear()}`;\n  }\n\n  function getToday() {\n    let date = new Date();\n    return `${date.getDate()}-${date.getMonth() + 1}-${date.getFullYear()}`;\n  }\n\n  function getOrders() {\n    setLoading(true);\n    //.where('owner', '==', currentUserId)\n    //.where('orderStatus', '!=', 'Order Close') // does not need index\n    //.where('score', '<=', 10)    // needs index\n    //.orderBy('owner', 'asc')\n    //.limit(3)\n    app\n      .firestore()\n      .collection(\"orders\")\n      .where(\"orderStatus\", \"!=\", \"Order Close\")\n      .onSnapshot((querySnapshot) => handleSnapshotData(querySnapshot));\n  }\n\n  function getOrderHistory() {\n    setLoading(true);\n    //.where('owner', '==', currentUserId)\n    //.where('orderStatus', '!=', 'Order Close') // does not need index\n    //.where('score', '<=', 10)    // needs index\n    //.orderBy('owner', 'asc')\n    //.limit(3)\n    app\n      .firestore()\n      .collection(\"orderHistory\")\n      .where(\"updatedTo\", \"!=\", \"Order Close\")\n      .onSnapshot((querySnapshot) => handleHistorySnapshotData(querySnapshot));\n  }\n\n  function handleSnapshotData(querySnapshot) {\n    const items = [];\n    querySnapshot.forEach((doc) => {\n      let _item = doc.data();\n      _item.id = doc.id;\n      items.push(_item);\n    });\n    // console.log(\"Dashboard:: Item Length:\", items.length);\n    if (items.length > 0) {\n      setInitOrderList(items);\n      // console.log(\"ssetting itm and calling calculate::: \", items.length, initOrderList.length);\n      setLoading(false);\n    }\n  }\n\n  function handleHistorySnapshotData(querySnapshot) {\n    const items = [];\n    querySnapshot.forEach((doc) => {\n      let _item = doc.data();\n      _item.id = doc.id;\n      items.push(_item);\n    });\n    // console.log(\"Dashboard:: Item Length:\", items.length);\n    if (items.length > 0) {\n      setInitOrderHistoryList(items);\n      // console.log(\"ssetting itm and calling calculate::: \", items.length, initOrderHistoryList.length);\n      setLoading(false);\n    }\n  }\n\n  useEffect(() => {\n    // console.log(getToday());\n    getOrders();\n    getOrderHistory();\n    // eslint-disable-next-line\n  }, []);\n\n  useEffect(() => {\n    calculate();\n    calculateSum(getDateFromString(new Date()));\n  }, [initOrderHistoryList]);\n\n  function handleDateChange(e) {\n    let date = getDateFromString(e.target.value);\n    setDate(date);\n    calculateSum(date);\n  }\n\n  function calculateSum(date) {\n    let orderByStatus = _.groupBy(initOrderHistoryList, \"updatedTo\");\n    let statusSum = {};\n    // console.log(orderByStatus);\n    let orderDetails = {};\n    Object.keys(orderByStatus).map((status) => {\n      let sumSqft = orderByStatus[status].reduce((sum, o) => {\n        let orderDate = o.updateDate;\n        if (orderDate === date) {\n          // console.log(`${status} - ${o.orderId}`);\n          let details = orderDetails[status] || [];\n          orderDetails[status] = [...details, { orderId: o.orderId, id: o.id }];\n          return sum + (parseFloat(o.orderSqFt) || 0);\n        } else {\n          return sum + 0;\n        }\n      }, 0);\n      statusSum[status] = sumSqft;\n    });\n    setOrderDetailsForDate(orderDetails);\n    setStatusOrdersSum(statusSum);\n  }\n\n  function calculate() {\n    // console.log(\"Init orderlist length::\", initOrderList.length);\n    let filteredOrders = initOrderList.filter(\n      (order) =>\n        order.orderStatus !== \"Order Close\" &&\n        order.orderStatus !== \"Dispatch\" &&\n        order.orderStatus !== \"Packed\"\n    );\n    setPendingOrdersCount(filteredOrders.length);\n    let orders = _.countBy(filteredOrders, \"orderType\");\n    let statusOrders = _.countBy(initOrderList, \"orderStatus\");\n    let orderByStatus = _.groupBy(initOrderList, \"orderStatus\");\n    setPendingOrders(orders);\n    setStatusOrders(statusOrders);\n    // console.log(\"Orders:::\", Object.entries(orders), initOrderList.length);\n  }\n\n  return (\n    <div>\n      {error && <Alert variant=\"danger\">{error}</Alert>}\n      {loading && <h1>Loading data....</h1>}\n\n      <>\n        <Card key=\"head-pending\">\n          <Card.Body>\n            <h2 className=\"text-center mb-4\">\n              Pending Orders ({pendingOrdersCount})\n            </h2>\n          </Card.Body>\n        </Card>\n        <div className=\"d-flex flex-wrap justify-content-around flex-fill\">\n          {Object.entries(pendingOrders).map((order) => (\n            <Card className=\"mb-2 w-25\" key={order.id}>\n              <Card.Header>\n                <Link to={`/list/orderType=${encodeURIComponent(order[0])}`}>\n                  {order[0]}\n                </Link>\n              </Card.Header>\n              <Card.Body>{order[1]}</Card.Body>\n            </Card>\n          ))}\n        </div>\n      </>\n\n      <>\n        <Card key=\"head-pending\">\n          <Card.Body>\n            <h2 className=\"text-center mb-4\">Orders By Status</h2>\n          </Card.Body>\n        </Card>\n        <div className=\"d-flex flex-wrap justify-content-around flex-fill\">\n          {Object.entries(statusOrders).map((order) => (\n            <Card className=\"mb-2 w-25\" key={order.id}>\n              <Card.Header>\n                <Link to={`/list/orderStatus=${order[0]}`}>{order[0]}</Link>\n              </Card.Header>\n              <Card.Body>{order[1]}</Card.Body>\n            </Card>\n          ))}\n        </div>\n      </>\n\n      <>\n        <Card key=\"head-pending\">\n          <Card.Body>\n            <h2 className=\"text-center mb-4\">Daily Work</h2>\n            <input\n              type=\"date\"\n              defaultValue={getToday}\n              onChange={handleDateChange}\n            />\n            <span> Date: {date}</span>\n          </Card.Body>\n        </Card>\n        <div className=\"d-flex flex-wrap justify-content-around flex-fill\">\n          {Object.entries(statusOrdersSum).map((order) => (\n            <Card className=\"mb-2 w-25\" key={order.id}>\n              <Card.Header>\n                <Link to={`/list/orderStatus=${order[0]}`}>{order[0]}</Link>\n              </Card.Header>\n              <Card.Body>\n                {Number(order[1]).toFixed(2)}\n                <div>\n                  <button\n                    className=\"btn btn-info my-2\"\n                    onClick={() => setShowMore(order[0])}\n                  >\n                    Show More\n                  </button>\n                </div>\n              </Card.Body>\n            </Card>\n          ))}\n        </div>\n      </>\n\n      <>\n        <Card>\n          <h2 className=\"text-center mb-4\">Order Details for Status</h2>\n          {Object.keys(orderDetailsForDate).length > 0 &&\n            Object.keys(orderDetailsForDate).map((status) => {\n              if (status === showMore)\n                return (\n                  <div>\n                    <Card>\n                      <Card.Header>{status}</Card.Header>\n                      <ul>\n                        {orderDetailsForDate[status].map((od) => (\n                          <li>\n                            {/* <Link to={`/detail/${od.id}`}>{od.orderId}</Link> */}\n                            {od.orderId}\n                          </li>\n                        ))}\n                      </ul>\n                    </Card>\n                  </div>\n                );\n              else return <></>;\n            })}\n        </Card>\n      </>\n    </div>\n  );\n}\n","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/Header.js",["71","72"],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/List.js",["73","74"],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/PrivateRoute.js",["75"],"import React from \"react\"\nimport { Route, Redirect } from \"react-router-dom\"\nimport { useAuth } from \"../contexts/AuthContext\"\nimport Header from \"./Header\"\n\nexport default function PrivateRoute({ component: Component, ...rest }) {\n  const { currentUser } = useAuth()\n\n  return (\n    <Route\n      {...rest}\n      render={props => {\n        return currentUser ? <Component {...props} /> : <Redirect to=\"/login\" />\n      }}\n    ></Route>\n  )\n}","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/Add.js",[],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/Login.js",[],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/Detail.js",["76","77","78","79","80","81"],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/AdminRoute.js",[],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/ManagerRoute.js",[],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/contexts/AuthContext.js",["82"],"import React, { useContext, useState, useEffect } from \"react\"\nimport { auth } from \"../firebase\"\n\nconst AuthContext = React.createContext()\n\nexport function useAuth() {\n  return useContext(AuthContext)\n}\n\nexport function AuthProvider({ children }) {\n  const [currentUser, setCurrentUser] = useState();\n  const [isAdmin, setIsAdmin] = useState(false);\n  const [isManager, setIsManager] = useState(false);\n  const [loading, setLoading] = useState(true);\n\n  function adminEmails() {\n    return ['vishal@neeommodular.com','chirag@neeommodular.com','office@neeommodular.com','admin@neeommodular.com'];\n  }\n\n\n  function signup(email, password) {\n    // return auth.createUserWithEmailAndPassword(email, password)\n  }\n\n  function login(email, password) {\n    return auth.signInWithEmailAndPassword(email, password)\n  }\n\n  function logout() {\n    return auth.signOut()\n  }\n\n  function resetPassword(email) {\n    return auth.sendPasswordResetEmail(email)\n  }\n\n  function updateEmail(email) {\n    return currentUser.updateEmail(email)\n  }\n\n  function updatePassword(password) {\n    return currentUser.updatePassword(password)\n  }\n\n  useEffect(() => {\n    const unsubscribe = auth.onAuthStateChanged(user => {\n      setCurrentUser(user)\n      let isAdmin = user ? adminEmails().includes(user.email) : false;\n      let regexMatch = [];\n      regexMatch = user ? user.email.match('manager[0-9]+@neeommodular.com') : []\n      let isManager = regexMatch ? regexMatch.length === 1 : false;\n      setIsAdmin(isAdmin);\n      setIsManager(isManager)\n      setLoading(false)\n    })\n\n    return unsubscribe\n  }, [])\n\n  const value = {\n    currentUser,\n    isAdmin,\n    isManager,\n    login,\n    logout,\n    resetPassword,\n    updateEmail,\n    updatePassword\n  }\n\n  return (\n    <AuthContext.Provider value={value}>\n      {!loading && children}\n    </AuthContext.Provider>\n  )\n}","/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/firebase.js",[],"/Users/vishaldharmawat/Developer/Projects/neeom-modular-dashboard/src/components/utils/index.js",[],{"ruleId":"83","severity":1,"message":"84","line":2,"column":16,"nodeType":"85","messageId":"86","endLine":2,"endColumn":22},{"ruleId":"83","severity":1,"message":"87","line":4,"column":10,"nodeType":"85","messageId":"86","endLine":4,"endColumn":17},{"ruleId":"83","severity":1,"message":"88","line":18,"column":17,"nodeType":"85","messageId":"86","endLine":18,"endColumn":25},{"ruleId":"89","severity":1,"message":"90","line":101,"column":6,"nodeType":"91","endLine":101,"endColumn":28,"suggestions":"92"},{"ruleId":"93","severity":1,"message":"94","line":114,"column":45,"nodeType":"95","messageId":"96","endLine":114,"endColumn":47},{"ruleId":"83","severity":1,"message":"97","line":143,"column":9,"nodeType":"85","messageId":"86","endLine":143,"endColumn":22},{"ruleId":"83","severity":1,"message":"98","line":11,"column":12,"nodeType":"85","messageId":"86","endLine":11,"endColumn":17},{"ruleId":"99","severity":1,"message":"100","line":38,"column":5,"nodeType":"101","endLine":38,"endColumn":42},{"ruleId":"93","severity":1,"message":"94","line":87,"column":23,"nodeType":"95","messageId":"96","endLine":87,"endColumn":25},{"ruleId":"83","severity":1,"message":"102","line":107,"column":11,"nodeType":"85","messageId":"86","endLine":107,"endColumn":16},{"ruleId":"83","severity":1,"message":"103","line":4,"column":8,"nodeType":"85","messageId":"86","endLine":4,"endColumn":14},{"ruleId":"83","severity":1,"message":"98","line":10,"column":10,"nodeType":"85","messageId":"86","endLine":10,"endColumn":15},{"ruleId":"83","severity":1,"message":"88","line":10,"column":17,"nodeType":"85","messageId":"86","endLine":10,"endColumn":25},{"ruleId":"83","severity":1,"message":"104","line":11,"column":10,"nodeType":"85","messageId":"86","endLine":11,"endColumn":19},{"ruleId":"83","severity":1,"message":"105","line":11,"column":21,"nodeType":"85","messageId":"86","endLine":11,"endColumn":33},{"ruleId":"83","severity":1,"message":"106","line":12,"column":10,"nodeType":"85","messageId":"86","endLine":12,"endColumn":17},{"ruleId":"83","severity":1,"message":"107","line":14,"column":33,"nodeType":"85","messageId":"86","endLine":14,"endColumn":42},{"ruleId":"83","severity":1,"message":"108","line":21,"column":12,"nodeType":"85","messageId":"86","endLine":21,"endColumn":18},"no-unused-vars","'Button' is defined but never used.","Identifier","unusedVar","'useAuth' is defined but never used.","'setError' is assigned a value but never used.","react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'calculate' and 'calculateSum'. Either include them or remove the dependency array.","ArrayExpression",["109"],"array-callback-return","Array.prototype.map() expects a return value from arrow function.","ArrowFunctionExpression","expectedInside","'orderByStatus' is assigned a value but never used.","'error' is assigned a value but never used.","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","'wbout' is assigned a value but never used.","'Header' is defined but never used.","'isChecked' is assigned a value but never used.","'setIsChecked' is assigned a value but never used.","'loading' is assigned a value but never used.","'isManager' is assigned a value but never used.","'signup' is defined but never used.",{"desc":"110","fix":"111"},"Update the dependencies array to be: [calculate, calculateSum, initOrderHistoryList]",{"range":"112","text":"113"},[3357,3379],"[calculate, calculateSum, initOrderHistoryList]"]